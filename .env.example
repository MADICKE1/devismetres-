# ========================================
# DEVIS-IA Pro - Variables d'Environnement
# ========================================

# Frontend - React
REACT_APP_API_URL=http://localhost:5000
REACT_APP_ENV=development
REACT_APP_CLAUDE_API_KEY=sk-ant-YOUR_CLAUDE_API_KEY_HERE

# Backend - Node.js/Express
PORT=5000
NODE_ENV=development

# Database - PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/devis_ia
DB_HOST=localhost
DB_PORT=5432
DB_USER=devis_user
DB_PASSWORD=your_secure_password_here
DB_NAME=devis_ia

# Authentication
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure
JWT_EXPIRATION=7d
BCRYPT_ROUNDS=10

# Claude API
ANTHROPIC_API_KEY=sk-ant-YOUR_CLAUDE_API_KEY_HERE
CLAUDE_MODEL=claude-opus-4-1
CLAUDE_VISION_MODEL=claude-opus-4-1

# Email Configuration (Optional - for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# AWS Configuration (Optional - for cloud deployment)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=devis-ia-uploads

# Stripe (Optional - for payment processing)
STRIPE_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Security
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Features Flags
ENABLE_PDF_EXPORT=true
ENABLE_EXCEL_EXPORT=true
ENABLE_JSON_API=true
ENABLE_REAL_TIME_ANALYSIS=true
ENABLE_EMAIL_NOTIFICATIONS=false

# File Upload
MAX_FILE_SIZE=50mb
ALLOWED_FILE_TYPES=pdf,dwg,jpg,png,jpeg
UPLOAD_DIR=./uploads

# Analytics (Optional)
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=google
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Development Tools
ENABLE_DEBUG_MODE=false
ENABLE_MOCK_DATA=false
MOCK_ANALYSIS_DELAY=2000

# ========================================
# Instructions:
# 1. Copier ce fichier en .env.local
# 2. Remplir toutes les valeurs avec vos clés
# 3. Ne pas commiter le fichier .env.local
# 4. Ajouter .env.local à .gitignore
# ========================================
